# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  .gitignore — Neovim Enterprise configuration                            ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Lazy.nvim lock  and LazyVim file 
lazy-lock.json
lazyvim.json

# Plugin runtime data
plugin/
spell/

# --- Neovim Runtime / State ---
# These are generated by Neovim during usage
shada/
undo/
swap/
backup/
*.log
*.tmp
*.swp
*.swo
*~
.netrwhist

# --- Local Secrets & Personal Settings ---
# Files that might contain local paths or API keys (like OpenAI/Copilot)
.netrc
*.secret
*.keys
secrets/
.env
.env.*
secret.lua
local.lua

# --- Plugin Manager (Lazy.nvim) ---
# We track lazy-lock.json but NOT the actual plugin source code
lazy-lock.json
# If you have a local 'dist' or 'build' for some plugins
build/

# --- Language Specific ---
# Ignore node_modules if you do any local JS/TS scripting for Neovim
node_modules/
.npm/
.python-version
__pycache__/
.venv/

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- NvimEnterprise Logs (from your config) ---
# Based on your NvimLogView command location
/state/nvimenterprise.log
*.log

# User namespaces with private data
# Uncomment to exclude specific user namespaces from git:
# lua/users/john/
# lua/users/jane/
# Keep shared infrastructure:
# !lua/users/init.lua
# !lua/users/user_manager.lua
# !lua/users/namespace.lua
# !lua/users/default/
