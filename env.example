#
# Models: gemini-2.5-pro, gemini-2.0-flash
# Dashboard: https://aistudio.google.com/apikey
# Pricing: https://ai.google.dev/pricing
# Used by: codecompanion.nvim
# ═══════════════════════════════════════════════════════════════════════════
GEMINI_API_KEY=your-gemini-api-key-here

